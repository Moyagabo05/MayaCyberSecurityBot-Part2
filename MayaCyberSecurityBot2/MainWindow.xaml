<Window x:Class="MayaCyberSecurityBot2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MayaCyberSecurityBot2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">


    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Header -->
        <Border Grid.Row="0" Background="#16213e" BorderBrush="#00d4ff" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="8">
            <StackPanel>
                <TextBlock x:Name="AsciiArtText" FontFamily="Consolas" FontSize="9" Foreground="#00d4ff" TextWrapping="Wrap" TextAlignment="Center"/>
                <TextBlock Text=" Maya Cybersecurity Assistant" FontSize="16" FontWeight="Bold" Foreground="#00d4ff" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Chat Display -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10">
            <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ChatMessages" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" Padding="10" CornerRadius="6" Background="{Binding Background}" HorizontalAlignment="{Binding Alignment}">
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="{Binding Foreground}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UserInput" Background="#0f3460" Foreground="White" BorderBrush="#00d4ff" Padding="10" FontSize="14" VerticalContentAlignment="Center" KeyDown="UserInput_KeyDown"/>
            <Button Grid.Column="1" Content="Send" Width="80" Margin="8,0,0,0" Background="#00d4ff" Foreground="#1a1a2e" FontWeight="Bold" Click="SendButton_Click"/>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="#0f3460" Foreground="#00d4ff">
            <TextBlock x:Name="StatusText" Text="Ready | Type 'help' for topics"/>
        </StatusBar>
    </Grid>

</Window>
